    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst fileItem  = items[0]?.json;\nconst siigoItem = items[1]?.json;\n\nlet processedData = [];\ntry {\n    if (Array.isArray(fileItem)) {\n        if (fileItem.length > 0 && fileItem[0].data_to_save && Array.isArray(fileItem[0].data_to_save)) {\n            processedData = fileItem[0].data_to_save;\n        } else {\n            processedData = fileItem;\n        }\n    } else if (fileItem && fileItem.data_to_save && Array.isArray(fileItem.data_to_save)) {\n        processedData = fileItem.data_to_save;\n    } else if (fileItem && fileItem.data && Array.isArray(fileItem.data)) {\n        processedData = fileItem.data;\n    }\n} catch (e) {\n    processedData = [];\n}\n\nconst allInvoices     = siigoItem?.results || [];\nconst processedNames  = new Set(processedData.map(p => p.name));\nconst newInvoices     = allInvoices.filter(inv => !processedNames.has(inv.name));\n\nconst updatedProcessed = [\n    ...processedData,\n    ...newInvoices.map(inv => ({ name: inv.name, id: inv.id, date: inv.date }))\n];\n\nconst trimmedProcessed = updatedProcessed.slice(-2000);\n\nreturn [{\n    json: {\n        new_invoices:       newInvoices,\n        new_count:          newInvoices.length,\n        all_invoices_count: allInvoices.length,\n        processed_count:    processedData.length,\n        data_to_save:       JSON.stringify(trimmedProcessed, null, 2)\n    }\n}];"
      },
