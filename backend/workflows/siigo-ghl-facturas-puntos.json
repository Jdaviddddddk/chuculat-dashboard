    {
      "parameters": {
        "jsCode": "const contact = $('Buscar contacto').first().json.contacts[0];\nconst cf = contact.customFields || [];\n\n// Leer por ID de campo (NO por posicion) con coercion numerica segura\nconst num = (id) => { const f = cf.find(x => x.id === id); const v = f ? Number(f.value) : 0; return isNaN(v) ? 0 : v; };\n\nconst PUNTOS_ID    = 'UfFc9GjS1K9az8nactO5'; // saldo de puntos\nconst HIST_ID      = 'ciYvzjlWfz9RcmIlqRkO'; // puntos historicos (total otorgado)\nconst HISTORIAL_ID = 'wdfNkPf305JjwPdTUBwS'; // fechas de recompra\n\nconst puntosActuales = num(PUNTOS_ID);\nconst puntosNuevos   = Number($('Code in JavaScript1').first().json.puntosGanados) || 0;\nconst totalPuntos    = puntosActuales + puntosNuevos;\nconst puntosHistory  = num(HIST_ID) + puntosNuevos;\n\nconst histField        = cf.find(f => f.id === HISTORIAL_ID);\nconst currentHistorial = histField?.value || '';\nconst today            = new Date().toISOString().split('T')[0];\nconst newHistorial     = currentHistorial ? currentHistorial + ',' + today : today;\nconst fechaUltimaRecompra = today;\n\n// ── Enriquecer: rellenar en GHL solo lo que FALTE, con el dato de Siigo ──\n// Nunca pisa un valor que GHL ya tenga: si existe, se reenvia el mismo.\nconst cli = (() => { try { return $('Cliente').first().json || {}; } catch (e) { return {}; } })();\nconst norm = t => String(t || '').replace(/[^0-9]/g, '').replace(/^57(?=\\d{10}$)/, '');\n\nconst telSiigo   = norm((cli.phones || [])[0]?.number);\nconst mailSiigo  = ((cli.contacts || [])[0]?.email || '').trim();\nconst nomSiigo   = [ (cli.contacts || [])[0]?.first_name, (cli.contacts || [])[0]?.last_name ].filter(Boolean).join(' ').trim();\n\nconst telGHL  = norm(contact.phone);\nconst mailGHL = String(contact.email || '').trim();\nconst nomGHL  = String(contact.name || '').trim();\n\n// valor final = el de GHL si lo tiene; si no, el de Siigo (puede quedar vacio)\nconst phone = telGHL  || telSiigo  || '';\nconst email = mailGHL || mailSiigo || '';\nconst name  = nomGHL  || nomSiigo  || '';\nconst completo = { phone: !!telGHL, email: !!mailGHL, name: !!nomGHL };\n\nreturn [{\n  json: { contactId: contact.id, puntosActuales, puntosNuevos, totalPuntos, puntosHistory, newHistorial, fechaUltimaRecompra,\n          phone, email, name, __yaTenia: completo }\n}];"
      },
