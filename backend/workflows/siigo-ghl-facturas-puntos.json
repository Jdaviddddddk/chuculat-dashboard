        "jsCode": "const items = $('Factura').first().json.results[0].items || [];\n\nlet subtotal = 0;\n\nfor (const item of items) {\n  const price = Number(item.price || 0);\n  const quantity = Number(item.quantity || 0);\n  subtotal += price * quantity;\n}\n\nreturn [{\n  json: {\n    ...$json,\n    subtotal_calculado: subtotal\n  }\n}];"
