    {
      "parameters": {
        "jsCode": "const contact = $input.first().json.contacts[0];\nconst cf = contact.customFields || [];\n\n// Puntos actuales y nuevo total\nconst puntosActuales = $('Buscar contacto').first().json.contacts[0].customFields[1].value;\nconst puntosNuevos   = $('Code in JavaScript1').first().json.puntosGanados;\nconst totalPuntos    = puntosActuales + puntosNuevos;\nconst puntosHistory  = $('Buscar contacto').first().json.contacts[0].customFields[3].value + totalPuntos;\n\n// Historial de recompras: leer campo actual y agregar fecha de hoy\nconst allCf = $('Buscar contacto').first().json.contacts[0].customFields || [];\nconst historicField    = allCf.find(f => f.id === 'wdfNkPf305JjwPdTUBwS');\nconst currentHistorial = historicField?.value || '';\nconst today            = new Date().toISOString().split('T')[0]; // YYYY-MM-DD\nconst newHistorial     = currentHistorial ? currentHistorial + ',' + today : today;\n\n// DESPUÉS\nconst fechaUltimaRecompra = new Date().toISOString().split('T')[0]; // \"2026-06-03\"\n\nreturn [{\n  json: {\n    contactId:           contact.id,\n    puntosActuales,\n    puntosNuevos,\n    totalPuntos,\n    puntosHistory,\n    newHistorial,\n    fechaUltimaRecompra\n  }\n}];"
      },
