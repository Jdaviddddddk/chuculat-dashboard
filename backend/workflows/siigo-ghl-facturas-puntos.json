    {
      "parameters": {
        "jsCode": "// Factura ACTUAL del loop (antes se usaba results[0] = siempre la primera del lote)\nlet inv = {};\ntry { inv = $('Loop Over Items').item.json || {}; } catch (e) { inv = {}; }\n\nconst cli   = $('Cliente').first().json || {};\nconst ident = String(cli.identification || '').trim();\nconst idtype= String((cli.id_type && cli.id_type.code) || '');\nconst ptype = String(cli.person_type || '');\nlet cname   = cli.name; cname = Array.isArray(cname) ? cname.join(' ') : String(cname || '');\n\nconst invDate = String(inv.date || '').slice(0, 10);\nconst cc      = Number(inv.cost_center);\n\nconst BLOCKED = new Set(['222222222222', '7777777777777']);\nconst LAURA   = /laura\\s+catalina\\s+le[oó]n/i;\nconst KW      = /\\b(s\\.?a\\.?s\\.?|ltda\\.?|factura|corp|inc|empresa|group|grupo|distribu|comercial|industria|hospitality|retail|inversiones)\\b/i;\nconst CUTOFF  = '2026-05-11';\n\n// cc 168 = B2C. Las 166 (B2B) / 315 (export) NO otorgan puntos.\nconst esNatural = cc === 168\n  && !BLOCKED.has(ident)\n  && ptype !== 'Company'\n  && idtype !== '31'\n  && !LAURA.test(cname)\n  && !KW.test(cname)\n  && !(invDate && invDate < CUTOFF);\n\nreturn [{ json: { ...$json, esNatural, __cc: cc, __invName: inv.name || '', __invDate: invDate } }];"
      },
