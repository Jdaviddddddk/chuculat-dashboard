    {
      "parameters": {
        "jsCode": "const BLOCKED_IDS = new Set(['7777777777777', '222222222222']);\n\nlet logs = [];\ntry {\n  const ex = $input.first().json;\n  if (Array.isArray(ex)) logs = ex;\n  else if (ex && ex.data && Array.isArray(ex.data)) logs = ex.data;\n} catch(e) { logs = []; }\n\nconst bc      = $('Buscar contacto').first().json.contacts[0] || {};\nconst invoice = $('Code in JavaScript1').first().json;\nconst puntos  = invoice.puntosGanados || 0;\n\nconst siigoId = String(invoice.identification || '').trim();\n\nif (BLOCKED_IDS.has(siigoId)) {\n  return [{ json: { logsStr: JSON.stringify(logs, null, 2), skipped: true, siigoId, total: logs.length } }];\n}\n\nconst entry = {\n  id:          Date.now().toString(36) + Math.random().toString(36).slice(2),\n  timestamp:   new Date().toISOString(),\n  date:        new Date().toISOString().split('T')[0],\n  type:        'suma_puntos',\n  contactId:   bc.id || '',\n  contactName: ((bc.firstName || '') + ' ' + (bc.lastName || '')).trim(),\n  phone:       bc.phone || '',\n  points:      puntos,\n  source:      'siigo',\n  invoiceId:   invoice.name || null,\n  siigoId:     siigoId || null\n};\nlogs.push(entry);\nreturn [{ json: { logsStr: JSON.stringify(logs, null, 2), entry, total: logs.length } }];"
      },
