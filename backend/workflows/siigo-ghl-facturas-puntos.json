    {
      "parameters": {
        "jsCode": "const BLOCKED_IDS=new Set(['7777777777777','222222222222']);\nconst bc=$('Buscar contacto').first().json.contacts[0]||{};\nconst invoice=$('Code in JavaScript1').first().json;\nlet fv='', fdate='';\ntry{ const f=$('Factura').first().json.results[0]; fv=f.name||''; fdate=String(f.date||'').slice(0,10); }catch(e){}\nconst puntos=Number(invoice.puntosGanados)||0;\nconst siigoId=String(invoice.identification||'').trim();\nif(BLOCKED_IDS.has(siigoId))return [];\nconst now=new Date();\nreturn [{ json: { ext_id: Date.now().toString(36)+Math.random().toString(36).slice(2), timestamp: (fdate?fdate+'T12:00:00Z':now.toISOString()), fecha: (fdate||now.toISOString().split('T')[0]), tipo:'suma_puntos', contact_id: bc.id||'', contact_name: ((bc.firstName||'')+' '+(bc.lastName||'')).trim(), phone: bc.phone||'', points: puntos, source:'siigo', invoice_id: fv||null, siigo_id: siigoId||null } }];"
      },
