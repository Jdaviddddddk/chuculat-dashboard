    "jsCode": "let processed=[];\ntry{const b=await this.helpers.getBinaryDataBuffer(0,'data');processed=JSON.parse(b.toString());if(!Array.isArray(processed))processed=[];}catch(e){processed=[];}\nconst orderId=String(($('Webhook').first().json.body.id)??'');\nif(!orderId)return [{json:{skip:true,reason:'sin order id'}}];\nif(processed.includes(orderId))return [{json:{skip:true,orderId}}];\nprocessed.push(orderId);\nreturn [{json:{skip:false,orderId,str:JSON.stringify(processed)}}];"
